datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?   @unique
  passwordHash  String?
  role          Role      @default(TOURIST)
  provider      Provider  @default(EMAIL)
  providerId    String?
  isVerified    Boolean   @default(false)
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
  reviews       Review[]
  itineraries   Itinerary[]
  guideBookings GuideBooking[]

  @@index([email])
  @@index([phone])
}

enum Role {
  TOURIST
  GUIDE
  VENDOR
  SITE_MANAGER
  TOURISM_OFFICER
  COLLECTOR
  SUPER_ADMIN
}

enum Provider {
  EMAIL
  GOOGLE
  PHONE
}

model OtpStore {
  id        String   @id @default(cuid())
  phone     String
  email     String?
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─────────────────────────────────────────
// DESTINATIONS
// ─────────────────────────────────────────

model Destination {
  id            String      @id @default(cuid())
  slug          String      @unique
  nameEn        String
  nameTa        String
  category      Category
  descriptionEn String      @db.Text
  descriptionTa String      @db.Text
  historyEn     String?     @db.Text
  historyTa     String?     @db.Text
  heroImage     String
  images        String[]
  videoUrl      String?
  latitude      Float
  longitude     Float
  openingHours  Json?
  entryFeeAdult Float?
  entryFeeChild Float?
  isFeatured    Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tickets       Ticket[]
  reviews       Review[]

  @@index([category])
  @@index([isFeatured])
}

enum Category {
  BEACH
  TEMPLE
  WILDLIFE
  WATERFALL
  ADVENTURE
  HERITAGE
  MUSEUM
  CULTURE
  SHOPPING
  FOOD
  RELIGIOUS
  PHOTOGRAPHY
}

// ─────────────────────────────────────────
// TICKET BOOKING
// ─────────────────────────────────────────

model Ticket {
  id              String        @id @default(cuid())
  destinationId   String
  destination     Destination   @relation(fields: [destinationId], references: [id])
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id])
  ticketType      TicketType
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  visitDate       DateTime
  qrCode          String        @unique
  qrCodeUrl       String
  isScanned       Boolean       @default(false)
  scannedAt       DateTime?
  scannedBy       String?
  createdAt       DateTime      @default(now())

  @@index([qrCode])
  @@index([destinationId])
}

enum TicketType {
  ADULT
  CHILD
  SENIOR
  FOREIGNER
}

// ─────────────────────────────────────────
// BOOKING (Unified)
// ─────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  type            BookingType
  status          BookingStatus @default(PENDING)
  totalAmount     Float
  currency        String        @default("INR")
  paymentId       String?       @unique
  paymentGateway  String?
  paymentStatus   PaymentStatus @default(PENDING)
  metadata        Json?
  tickets         Ticket[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

enum BookingType {
  TICKET
  HOTEL
  GUIDE
  RENTAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────
// HOTELS
// ─────────────────────────────────────────

model Hotel {
  id            String    @id @default(cuid())
  nameEn        String
  nameTa        String
  type          HotelType
  descriptionEn String    @db.Text
  descriptionTa String    @db.Text
  address       String
  latitude      Float
  longitude     Float
  pricePerNight Float
  starRating    Int?
  images        String[]
  amenities     String[]
  phone         String?
  website       String?
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  reviews       Review[]

  @@index([type])
}

enum HotelType {
  GOVERNMENT
  LUXURY
  MID_RANGE
  BUDGET
  HOMESTAY
  RESORT
}

// ─────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────

model Event {
  id            String    @id @default(cuid())
  titleEn       String
  titleTa       String
  descriptionEn String    @db.Text
  descriptionTa String    @db.Text
  type          EventType
  venue         String
  latitude      Float?
  longitude     Float?
  startDate     DateTime
  endDate       DateTime
  image         String?
  isGovernment  Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([startDate])
  @@index([type])
}

enum EventType {
  CULTURAL
  FESTIVAL
  TEMPLE
  GOVERNMENT
  SPORTS
  FOOD
  MUSIC
}

// ─────────────────────────────────────────
// BLOGS
// ─────────────────────────────────────────

model Blog {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleEn       String
  titleTa       String
  contentEn     String    @db.Text
  contentTa     String    @db.Text
  excerpt       String
  coverImage    String
  category      BlogCategory
  tags          String[]
  authorId      String
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
}

enum BlogCategory {
  TRAVEL_STORY
  HISTORY
  CULTURE
  FOOD
  GUIDE
  GOVERNMENT
  REVIEW
}

// ─────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────

model GalleryItem {
  id          String      @id @default(cuid())
  type        MediaType
  url         String
  thumbnail   String?
  titleEn     String?
  titleTa     String?
  location    String?
  tags        String[]
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  uploadedBy  String?
  createdAt   DateTime    @default(now())

  @@index([type])
}

enum MediaType {
  PHOTO
  VIDEO
  DRONE
}

// ─────────────────────────────────────────
// GUIDES
// ─────────────────────────────────────────

model Guide {
  id          String    @id @default(cuid())
  userId      String    @unique
  nameEn      String
  nameTa      String
  bio         String    @db.Text
  languages   String[]
  experience  Int
  photo       String?
  licenseNo   String    @unique
  isVerified  Boolean   @default(false)
  ratePerDay  Float
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())

  bookings    GuideBooking[]
  reviews     Review[]

  @@index([isVerified, isAvailable])
}

model GuideBooking {
  id          String        @id @default(cuid())
  guideId     String
  guide       Guide         @relation(fields: [guideId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      BookingStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime      @default(now())

  @@index([guideId])
  @@index([userId])
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  destinationId   String?
  destination     Destination? @relation(fields: [destinationId], references: [id])
  hotelId         String?
  hotel           Hotel?    @relation(fields: [hotelId], references: [id])
  guideId         String?
  guide           Guide?    @relation(fields: [guideId], references: [id])
  rating          Int
  comment         String    @db.Text
  isApproved      Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([destinationId])
  @@index([hotelId])
}

// ─────────────────────────────────────────
// ITINERARY (AI Generated)
// ─────────────────────────────────────────

model Itinerary {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  days        Int
  data        Json
  budget      Float?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────
// EMERGENCY CONTACTS
// ─────────────────────────────────────────

model EmergencyContact {
  id        String          @id @default(cuid())
  nameEn    String
  nameTa    String
  type      EmergencyType
  phone     String
  address   String?
  latitude  Float?
  longitude Float?
  isActive  Boolean         @default(true)

  @@index([type])
}

enum EmergencyType {
  HOSPITAL
  POLICE
  FIRE
  TOURIST_HELPLINE
  WOMEN_SAFETY
  AMBULANCE
}

// ─────────────────────────────────────────
// GOVERNMENT ANNOUNCEMENTS
// ─────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  titleEn     String
  titleTa     String
  contentEn   String    @db.Text
  contentTa   String    @db.Text
  type        String
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────
// DOWNLOADS
// ─────────────────────────────────────────

model Download {
  id          String    @id @default(cuid())
  titleEn     String
  titleTa     String
  fileUrl     String
  fileType    String
  category    String
  downloadCount Int     @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────
// INFRASTRUCTURE REPORT (Report Infra Tab)
// ─────────────────────────────────────────

model InfraReport {
  id          String          @id @default(cuid())
  userId      String?
  location    String
  type        InfraIssueType
  description String          @db.Text
  images      String[]
  status      ReportStatus    @default(OPEN)
  latitude    Float?
  longitude   Float?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())

  @@index([status])
}

enum InfraIssueType {
  TOILET
  LIGHTING
  ROAD
  SIGNAGE
  SAFETY
  CLEANLINESS
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

// ─────────────────────────────────────────
// ADMIN ANALYTICS SNAPSHOT (lightweight)
// ─────────────────────────────────────────

model AnalyticsSnapshot {
  id              String    @id @default(cuid())
  date            DateTime  @unique @default(now())
  totalVisitors   Int       @default(0)
  ticketsSold     Int       @default(0)
  revenue         Float     @default(0)
  topDestination  String?
  newUsers        Int       @default(0)
  createdAt       DateTime  @default(now())
}
